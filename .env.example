ENVIRONMENT=local
LOG_LEVEL=INFO

# mock, openai, or vllm
MODEL_PROVIDER=mock
PRODUCTION_MODEL=Qwen3-32B-MN-Lendex
TEACHER_MODEL=Qwen3-235B-A22B-Instruct-2507

# OpenAI-compatible hosted Qwen endpoint.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Local or remote vLLM OpenAI-compatible server.
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=local-vllm

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://mongolian:language@postgres:5432/mongolian_language
GLOSSARY_DIR=app/glossaries
CACHE_TTL_SECONDS=3600

POSTGRES_USER=mongolian
POSTGRES_PASSWORD=language
POSTGRES_DB=mongolian_language
